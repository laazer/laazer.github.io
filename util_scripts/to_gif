#!/usr/bin/env bash

set -e

# --- Defaults ---
SPEED=1
OUTPUT=""
FPS=15
SCALE=480

# --- Usage ---
usage() {
  echo "Usage: $0 input.mov [output.gif] [speed]"
  echo ""
  echo "Examples:"
  echo "  $0 clip.mov"
  echo "  $0 clip.mov output.gif"
  echo "  $0 clip.mov output.gif 2"
  echo "  $0 clip.mov '' 1.5"
  exit 1
}

# --- Args ---
INPUT="$1"
OUTPUT="$2"
SPEED="$3"

[[ -z "$INPUT" ]] && usage

if [[ ! -f "$INPUT" ]]; then
  echo "Error: Input file not found: $INPUT"
  exit 1
fi

# Default output name
if [[ -z "$OUTPUT" ]]; then
  OUTPUT="${INPUT%.*}.gif"
fi

# Default speed
if [[ -z "$SPEED" ]]; then
  SPEED=1
fi

# Calculate setpts (inverse of speed)
# setpts = 1/speed
SETPTS=$(awk "BEGIN { printf \"%.5f\", 1/$SPEED }")

PALETTE="/tmp/palette_$$.png"

echo "Input:  $INPUT"
echo "Output: $OUTPUT"
echo "Speed:  ${SPEED}x"
echo "setpts: ${SETPTS}*PTS"

# --- Generate palette ---
ffmpeg -y -i "$INPUT" \
  -vf "setpts=${SETPTS}*PTS,fps=${FPS},scale=${SCALE}:-1:flags=lanczos,palettegen" \
  "$PALETTE"

# --- Generate gif ---
ffmpeg -y -i "$INPUT" -i "$PALETTE" \
  -filter_complex "setpts=${SETPTS}*PTS,fps=${FPS},scale=${SCALE}:-1:flags=lanczos[x];[x][1:v]paletteuse" \
  "$OUTPUT"

# Cleanup
rm -f "$PALETTE"

echo "✅ Done: $OUTPUT"